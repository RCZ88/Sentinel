# Sentinel — environment configuration
# Copy this file to ".env" (same folder as config.yaml) and fill in what you need.
#
# Everything here is OPTIONAL. Sentinel scans, quarantines and restores fully
# offline without any of these. They only power the AI "Explain" feature.
# Real environment variables and values saved from the UI take precedence.

# --- AI explanations (OpenRouter / any OpenAI-compatible API) ----------------

# Your OpenRouter API key: https://openrouter.ai/keys
# You can also paste this in the app under Settings → AI — saving there writes
# it straight back into this .env file for you.
OPENROUTER_API_KEY=

# Which model to use. Any OpenRouter model id works. Examples:
#   openai/gpt-4o-mini              (fast + cheap, default)
#   openai/gpt-4o
#   anthropic/claude-3.5-sonnet
#   google/gemini-flash-1.5
#   meta-llama/llama-3.1-70b-instruct
#   deepseek/deepseek-chat
OPENROUTER_MODEL=openai/gpt-4o-mini

# OpenAI-compatible base URL. Only change this to use a different provider/proxy.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Turn the AI feature on/off. If a key is present, AI is auto-enabled, so you can
# usually leave this as-is.
SENTINEL_AI_ENABLED=false
