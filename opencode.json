{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ".opencode\\plugins\\graphify.js"
  ],
  "mcp": {
    "@21st-dev/magic": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@21st-dev/magic@latest"
      ],
      "environment": {
        "API_KEY": "${MAGIC_API_KEY}"
      },
      "enabled": true
    },
    "probe": {
      "type": "local",
      "command": ["node", "C:/Users/cleme/Documents/COMPUTAH_SAYENCE/probe/dist/index.js"],
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@suekou/mcp-notion-server"
      ],
      "environment": {
        "NOTION_API_TOKEN": "${NOTION_API_TOKEN}"
      },
      "enabled": true
    }
  },
  "snapshot": false
}